{
  "name": "resumesite",
  "version": "1.0.0",
  "description": "Personal portfolio website for Michael LaPlante",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "npx serve .",
    "lint:css": "npx stylelint 'css/**/*.css' --fix",
    "lint:js": "npx eslint js/script.js --fix",
    "minify:css": "npx clean-css-cli -o css/style.min.css css/style.css",
    "minify:js": "npx terser js/script.js -o js/script.min.js -c -m",
    "build": "npm run minify:css && npm run minify:js",
    "blog:dev": "cd blog-src && npm run dev",
    "blog:build": "find blog-src/src -name 'CLAUDE.md' -delete && cd blog-src && npm run build && rm -rf ../blog/CLAUDE",
    "blog:preview": "cd blog-src && npm run preview",
    "blog:draft:git": "node scripts/generate-post.js git",
    "blog:draft:topic": "node scripts/generate-post.js topic"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mlaplante/resumesite"
  },
  "author": "Michael LaPlante",
  "license": "MIT",
  "keywords": [
    "portfolio",
    "resume",
    "personal-website"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0"
  }
}
