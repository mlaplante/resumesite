---
import type { GetStaticPaths } from 'astro';
import BlogLayout from '../../layouts/BlogLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getReadTime } from '../../utils/readTime';
import { formatDateShort } from '../../utils/format';
import { getSortedPosts } from '../../utils/posts';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getSortedPosts();
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const posts = page.data;
const isFirstPage = page.currentPage === 1;
const [newestPost, ...remainingPosts] = posts;
// Categories come from the whole archive, not just this page's 10 posts —
// otherwise the button row varies between pages and can omit categories.
const allPosts = await getSortedPosts();
const categories = ['all', ...new Set(allPosts.map((p) => p.data.category))];
---

<BlogLayout title="Blog" description="Thoughts on security, engineering, and building things.">
  <div class="listing-wrapper">
    <h1>Blog</h1>
    <p class="blog-subtitle">Thoughts on security, engineering, and building things.</p>

    <div class="search-box">
      <input
        type="search"
        id="blog-search"
        placeholder="Search posts..."
        autocomplete="off"
        aria-label="Search all blog posts"
      />
    </div>

    <div class="category-filter" role="group" aria-label="Filter posts by category">
      {categories.map((cat) => (
        <button
          class:list={['filter-btn', { active: cat === 'all' }]}
          data-category={cat}
          aria-pressed={cat === 'all' ? 'true' : 'false'}
        >
          {cat === 'all' ? 'All' : cat.replace(/-/g, ' ')}
        </button>
      ))}
    </div>

    {posts.length === 0 && <p class="no-posts">No posts yet. Check back soon.</p>}

    {isFirstPage && newestPost && (
      <a href={`/blog/${newestPost.id}/`} class="post-card post-card-featured" data-category={newestPost.data.category}>
        <div class="post-card-meta">
          <time datetime={newestPost.data.date.toISOString()}>{formatDateShort(newestPost.data.date)}</time>
          <span class="dot-sep">&middot;</span>
          <span>{getReadTime(newestPost.body)} min read</span>
        </div>
        <h2>{newestPost.data.title}</h2>
        <p>{newestPost.data.excerpt}</p>
        <span class="category-badge">{newestPost.data.category.replace(/-/g, ' ')}</span>
      </a>
    )}

    <!-- Sponsored/Featured Content Slot -->
    <div class="featured-banner">
      <div class="featured-banner-content">
        <span class="featured-label">Services</span>
        <h3>Security Consulting & Architecture Reviews</h3>
        <p>15+ years of experience in enterprise security. I help teams build secure, scalable systems.</p>
        <a href="/#contact" class="featured-cta">Get in touch &rarr;</a>
      </div>
    </div>

    <p class="search-status" id="search-status" role="status" aria-live="polite" hidden></p>

    <div class="post-grid" id="search-results" hidden></div>

    <div class="post-grid" id="page-grid">
      {(isFirstPage ? remainingPosts : posts).map((post) => {
        const readTime = getReadTime(post.body);
        return (
          <a href={`/blog/${post.id}/`} class="post-card" data-category={post.data.category}>
            <div class="post-card-meta">
              <time datetime={post.data.date.toISOString()}>
                {formatDateShort(post.data.date)}
              </time>
              <span class="dot-sep">&middot;</span>
              <span>{readTime} min read</span>
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.excerpt}</p>
            <span class="category-badge">{post.data.category.replace(/-/g, ' ')}</span>
          </a>
        );
      })}
    </div>

    {page.lastPage > 1 && (
      <nav class="pagination" aria-label="Blog pages">
        {page.url.prev ? (
          <a href={page.url.prev} class="pagination-link pagination-prev">&larr; Newer posts</a>
        ) : (
          <span class="pagination-link pagination-prev disabled">&larr; Newer posts</span>
        )}
        <span class="pagination-info">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next ? (
          <a href={page.url.next} class="pagination-link pagination-next">Older posts &rarr;</a>
        ) : (
          <span class="pagination-link pagination-next disabled">Older posts &rarr;</span>
        )}
      </nav>
    )}

    <!-- Newsletter Signup -->
    <NewsletterSignup
      variant="centered"
      heading="Subscribe to the newsletter"
      description="New posts on security, AI, and engineering delivered to your inbox. No spam, unsubscribe anytime."
    />
  </div>
</BlogLayout>

<style>
  .listing-wrapper {
    max-width: 720px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .listing-wrapper {
      max-width: 900px;
    }
  }

  .blog-subtitle {
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    color: #6b7280;
    margin-bottom: 32px;
    font-weight: 400;
  }

  .search-box {
    margin-bottom: 20px;
  }

  .search-status {
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    color: #9ca3af;
    margin: -8px 0 24px;
  }

  #blog-search {
    width: 100%;
    padding: 12px 16px;
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
    color: #1a1a1a;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  #blog-search::placeholder {
    color: #9ca3af;
  }

  #blog-search:focus {
    border-color: #2980b9;
    box-shadow: 0 0 0 3px rgba(41, 128, 185, 0.1);
  }

  .category-filter {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 6px 16px;
    border: 1px solid #e5e7eb;
    border-radius: 100px;
    background: transparent;
    cursor: pointer;
    color: #6b7280;
    transition: all 0.2s;
    text-transform: capitalize;
  }

  .filter-btn:hover {
    border-color: #2980b9;
    color: #2980b9;
  }

  .filter-btn.active {
    background: #2980b9;
    color: #fff;
    border-color: #2980b9;
  }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .post-grid {
      gap: 24px;
      grid-template-columns: 1fr 1fr;
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    padding: 18px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s;
  }

  @media (min-width: 768px) {
    .post-card {
      padding: 24px;
    }
  }

  .post-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border-color: #d1d5db;
    transform: translateY(-2px);
  }

  .post-card h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #111827;
    margin: 8px 0;
    line-height: 1.35;
    letter-spacing: -0.2px;
  }

  .post-card p {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #6b7280;
    margin: 0;
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .post-card p {
      -webkit-line-clamp: 4;
    }
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    color: #9ca3af;
    font-weight: 400;
  }

  .dot-sep {
    color: #d1d5db;
  }

  .category-badge {
    display: inline-block;
    margin-top: 14px;
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #2980b9;
    background: rgba(41, 128, 185, 0.08);
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: capitalize;
    width: fit-content;
  }

  .no-posts {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #9ca3af;
    text-align: center;
    padding: 60px 0;
    grid-column: 1 / -1;
  }

  /* Featured/Sponsored Banner */
  .featured-banner {
    margin-bottom: 24px;
    padding: 20px 22px;
    background: linear-gradient(135deg, rgba(41, 128, 185, 0.06) 0%, rgba(41, 128, 185, 0.02) 100%);
    border: 1px solid rgba(41, 128, 185, 0.15);
    border-radius: 12px;
  }

  @media (min-width: 768px) {
    .featured-banner {
      margin-bottom: 32px;
      padding: 28px 32px;
    }
  }

  .featured-label {
    font-family: 'Poppins', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #2980b9;
    background: rgba(41, 128, 185, 0.08);
    padding: 3px 10px;
    border-radius: 100px;
  }

  .featured-banner h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #111827;
    margin: 10px 0 6px;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .featured-banner h3 {
      font-size: 20px;
      margin: 12px 0 8px;
    }
  }

  .featured-banner p {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #6b7280;
    margin: 0 0 16px;
    line-height: 1.6;
  }

  .featured-cta {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #2980b9;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .featured-cta:hover {
    opacity: 0.7;
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 40px;
    padding: 16px 0;
    border-top: 1px solid #e5e7eb;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
  }

  .pagination-link {
    font-weight: 500;
    color: #2980b9;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .pagination-link:hover {
    opacity: 0.7;
  }

  .pagination-link.disabled {
    color: #d1d5db;
    pointer-events: none;
  }

  .pagination-info {
    color: #6b7280;
    font-size: 13px;
  }

  /* Dark mode */
  :global([data-theme='dark']) #blog-search { border-color: #334155; color: #f1f5f9; background: #1e293b; }
  :global([data-theme='dark']) #blog-search::placeholder { color: #64748b; }
  :global([data-theme='dark']) #blog-search:focus { border-color: #1a5276; box-shadow: 0 0 0 3px rgba(26, 82, 118, 0.2); }
  :global([data-theme='dark']) .blog-subtitle { color: #94a3b8; }
  :global([data-theme='dark']) .search-status { color: #64748b; }
  :global([data-theme='dark']) .filter-btn { border-color: #334155; color: #94a3b8; }
  :global([data-theme='dark']) .filter-btn:hover { border-color: #1a5276; color: #60a5fa; }
  :global([data-theme='dark']) .filter-btn.active { background: #1a5276; border-color: #1a5276; color: #fff; }
  :global([data-theme='dark']) .post-card { background: #1e293b; border-color: #334155; }
  :global([data-theme='dark']) .post-card:hover { box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3); border-color: #475569; }
  :global([data-theme='dark']) .post-card h2 { color: #f1f5f9; }
  :global([data-theme='dark']) .post-card p { color: #94a3b8; }
  :global([data-theme='dark']) .post-card-meta { color: #64748b; }
  :global([data-theme='dark']) .dot-sep { color: #475569; }
  :global([data-theme='dark']) .category-badge { color: #60a5fa; background: rgba(96, 165, 250, 0.1); }
  :global([data-theme='dark']) .no-posts { color: #64748b; }
  :global([data-theme='dark']) .featured-banner { background: linear-gradient(135deg, rgba(26, 82, 118, 0.15) 0%, rgba(26, 82, 118, 0.05) 100%); border-color: rgba(96, 165, 250, 0.15); }
  :global([data-theme='dark']) .featured-label { color: #60a5fa; background: rgba(96, 165, 250, 0.1); }
  :global([data-theme='dark']) .featured-banner h3 { color: #f1f5f9; }
  :global([data-theme='dark']) .featured-banner p { color: #94a3b8; }
  :global([data-theme='dark']) .featured-cta { color: #60a5fa; }
  :global([data-theme='dark']) .pagination { border-top-color: #334155; }
  :global([data-theme='dark']) .pagination-link { color: #60a5fa; }
  :global([data-theme='dark']) .pagination-link.disabled { color: #475569; }
  :global([data-theme='dark']) .pagination-info { color: #94a3b8; }

  /* Executive-security visual identity overrides. */
  .listing-wrapper h1,
  .post-card h2,
  .featured-banner h3 {
    font-family: var(--display-font);
    letter-spacing: -0.02em;
  }
  .blog-subtitle { color: var(--slate); }
  .post-card {
    position: relative;
    overflow: hidden;
    border: 0;
    border-radius: 8px;
    background: var(--surface);
    box-shadow: var(--shadow);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .post-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: 2px;
    background: transparent;
    transition: background-color .2s ease;
  }
  @media (hover: hover) {
    .post-card:hover { transform: translateY(-2px); border-color: transparent; box-shadow: 0 18px 42px rgba(10, 21, 40, .14); }
    .post-card:hover::before { background: var(--signal); }
  }
  .post-card h2 { color: var(--ink); }
  .post-card-meta { font-family: var(--mono-font); font-size: 11px; letter-spacing: .04em; color: var(--slate); }
  .post-card p { color: var(--slate); }
  .category-badge {
    font-family: var(--mono-font);
    font-size: 10px;
    letter-spacing: .06em;
    color: var(--signal-deep);
    background: rgba(226, 163, 60, .12);
    text-transform: uppercase;
  }
  .post-card-featured {
    display: flex;
    min-height: 300px;
    margin-bottom: 24px;
    padding: 30px;
    background: var(--ink);
    box-shadow: none;
  }
  .post-card-featured::before { background: var(--signal); }
  .post-card-featured h2 { max-width: 760px; font-size: clamp(1.75rem, 4vw, 2.8rem); color: var(--paper); }
  .post-card-featured p { max-width: 700px; color: #B9C5D5; }
  .post-card-featured .post-card-meta { color: #B9C5D5; }
  .post-card-featured .category-badge { color: var(--ink); background: var(--signal); }
  .featured-banner { background: var(--ink-2); border: 0; border-radius: 8px; }
  .featured-label { font-family: var(--mono-font); font-size: 10px; letter-spacing: .08em; color: var(--ink); background: var(--signal); }
  .featured-banner h3 { color: var(--paper); }
  .featured-banner p { color: #B9C5D5; }
  .featured-cta { color: var(--signal); }
  :global([data-theme='dark']) .post-card:not(.post-card-featured) { background: var(--ink-2); box-shadow: var(--shadow); }
  :global([data-theme='dark']) .post-card h2 { color: var(--paper); }
  :global([data-theme='dark']) .post-card p,
  :global([data-theme='dark']) .post-card-meta { color: var(--text-muted); }
  :global([data-theme='dark']) .featured-banner { background: var(--ink-2); }
</style>

<script>
  import { filterPosts, renderPostCard, describeResults, type IndexedPost } from '../../utils/search';

  const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
  const pageGrid = document.getElementById('page-grid');
  const resultsGrid = document.getElementById('search-results');
  const status = document.getElementById('search-status');
  const featuredBanner = document.querySelector('.featured-banner') as HTMLElement | null;
  const pagination = document.querySelector('.pagination') as HTMLElement | null;

  // The listing's card styles are scoped (`.post-card[data-astro-cid-*]`), so
  // injected cards must carry the same attribute or they render unstyled.
  // Read it off the results grid, which is part of the static template.
  const scopeAttr =
    resultsGrid?.getAttributeNames().find((n) => n.startsWith('data-astro-cid-')) ?? '';

  // The blog is paginated 10 posts at a time, so the rendered cards only cover
  // the current page. Searching — or picking a category — loads a static index
  // of every post and renders matches across the whole archive; clearing both
  // restores the paged view.
  let indexPromise: Promise<IndexedPost[]> | null = null;
  function loadIndex(): Promise<IndexedPost[]> {
    if (!indexPromise) {
      indexPromise = fetch('/blog/search.json')
        .then((res) => (res.ok ? res.json() : []))
        .catch(() => []);
    }
    return indexPromise;
  }

  function activeCategory(): string {
    const activeBtn = document.querySelector('.filter-btn.active') as HTMLElement | null;
    return activeBtn?.getAttribute('data-category') || 'all';
  }

  function renderResults(posts: IndexedPost[], query: string, cat: string) {
    const matches = filterPosts(posts, query, cat);
    if (resultsGrid) {
      resultsGrid.innerHTML = matches.map((post) => renderPostCard(post, scopeAttr)).join('');
    }
    if (status) {
      status.hidden = false;
      status.textContent = describeResults(matches.length, query, cat);
    }
  }

  function showSearchView(show: boolean) {
    if (pageGrid) pageGrid.hidden = show;
    if (resultsGrid) resultsGrid.hidden = !show;
    if (featuredBanner) featuredBanner.hidden = show;
    if (pagination) pagination.hidden = show;
    if (status && !show) status.hidden = true;
  }

  async function update() {
    const query = searchInput?.value.trim() || '';
    const cat = activeCategory();
    if (query || cat !== 'all') {
      const posts = await loadIndex();
      showSearchView(true);
      renderResults(posts, query, cat);
    } else {
      showSearchView(false);
    }
  }

  document.querySelectorAll('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      update();
    });
  });

  searchInput?.addEventListener('input', () => update());
</script>
