---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import { getReadTime } from '../utils/readTime';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<SiteLayout title="Michael LaPlante - SVP of Information Security and Operations | Technology Leader | Security Executive | Software Engineer" description="Michael LaPlante - Technology executive with 15+ years of experience in information security, operations, and software engineering. SVP of Information Security and Operations.">
  <Fragment slot="head">
    <!-- SEO Meta Tags -->
    <meta name="keywords" content="Michael LaPlante, Information Security, Technology Leader, Software Engineer, SVP, Chief Security Officer, Web Development">
    <meta name="author" content="Michael LaPlante">

    <!-- Canonical URL -->
    <link rel="canonical" href="https://michaellaplante.com/">

    <!-- Structured Data - Person -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Michael LaPlante",
      "url": "https://michaellaplante.com",
      "image": "https://res.cloudinary.com/laplantedev/image/upload/v1732243228/2023-inductees-la-plante-square_wwy6ir.jpg",
      "jobTitle": "SVP of Information Security and Operations",
      "worksFor": {
        "@type": "Organization",
        "name": "Proforma"
      },
      "description": "Technology executive with 15+ years of experience in information security, operations, and software engineering.",
      "knowsAbout": ["Information Security", "Software Engineering", "Cloud Security", "AI Security", "Web Development", "TypeScript", "React", "Angular"],
      "sameAs": [
        "https://www.linkedin.com/in/mlaplante/",
        "https://twitter.com/laplantewebdev",
        "https://github.com/mlaplante",
        "https://www.facebook.com/Laplante.Michael"
      ]
    }
    </script>

    <!-- Structured Data - WebSite (enables sitelinks search in Google) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Michael LaPlante",
      "url": "https://michaellaplante.com",
      "description": "Technology executive with 15+ years of experience in information security, operations, and software engineering.",
      "author": {
        "@type": "Person",
        "name": "Michael LaPlante"
      }
    }
    </script>

    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content="Michael LaPlante - Technology Leader & Security Executive">
    <meta property="og:description" content="Technology executive with 15+ years of experience in information security, operations, and software engineering.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://michaellaplante.com">
    <meta property="og:image" content="https://res.cloudinary.com/laplantedev/image/upload/v1732243228/2023-inductees-la-plante-square_wwy6ir.jpg">

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@laplantewebdev">
    <meta name="twitter:title" content="Michael LaPlante - Technology Leader & Security Executive">
    <meta name="twitter:description" content="Technology executive with 15+ years of experience in information security, operations, and software engineering.">
    <meta name="twitter:image" content="https://res.cloudinary.com/laplantedev/image/upload/v1732243228/2023-inductees-la-plante-square_wwy6ir.jpg">

    <!-- Preload Critical Resources -->
    <link rel="preload" href="/fonts/poppins/poppins-400.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/poppins/poppins-700.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/css/style.css" as="style">

    <!-- CSS Stylesheets -->
    <link rel="stylesheet" type="text/css" href="/css/fonts.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap-reboot.min.css" rel="stylesheet" integrity="sha384-DMXPlKUqiacJPvmloxO8WEKmweTP1X7QWc/yGAFhycsyFqem+stvdOQ4mrtuETGJ" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap-grid.min.css" rel="stylesheet" integrity="sha384-fmZzkB5FaSyz2fHsFdE3/hJZL5DoXoksqtGmj/ceh67vi7uY+MXjBITJATdQsrMM" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap-utilities.min.css" rel="stylesheet" integrity="sha384-Q51rgXP88lzrflg5bs/XnX/2BpyaSqnUXdNLptG3K+bDUcIxjjls1yD3RZIKZE+o" crossorigin="anonymous">
    <link rel="stylesheet" type="text/css" href="/css/linea.css">
    <link rel="stylesheet" type="text/css" href="/css/waves.min.css">
    <link rel="stylesheet" type="text/css" href="/css/owl.carousel.css">
    <link rel="stylesheet" type="text/css" href="/css/style.css">
  </Fragment>

  <!-- Skip to Content Link for Accessibility -->
  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <!--========================================
    Menu
  =========================================-->
