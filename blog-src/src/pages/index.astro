---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = ['all', ...new Set(posts.map((p) => p.data.category))];
---

<BlogLayout title="Blog" description="Thoughts on security, engineering, and building things.">
  <h1>Blog</h1>
  <p class="blog-subtitle">Thoughts on security, engineering, and building things.</p>

  <div class="search-box">
    <input type="text" id="blog-search" placeholder="search posts..." autocomplete="off" />
  </div>

  <div class="category-filter">
    {categories.map((cat) => (
      <button class="filter-btn" data-category={cat}>
        {cat === 'all' ? 'All' : cat.replace(/-/g, ' ')}
      </button>
    ))}
  </div>

  {posts.length === 0 && <p class="no-posts">No posts yet. Check back soon.</p>}

  <div class="post-list">
    {posts.map((post) => (
      <a href={`${import.meta.env.BASE_URL}/${post.id}/`} class="post-card" data-category={post.data.category}>
        <div class="post-card-meta">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span class="category">{post.data.category.replace(/-/g, ' ')}</span>
        </div>
        <h2>{post.data.title}</h2>
        <p>{post.data.excerpt}</p>
        <div class="post-tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</BlogLayout>

<style>
  .blog-subtitle {
    font-family: 'Roboto Mono', monospace;
    font-size: 14px;
    color: #6b7280;
    margin-bottom: 32px;
  }

  .category-filter {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: 'Roboto Mono', monospace;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: lowercase;
    padding: 7px 14px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    color: #4b5563;
    transition: all 0.2s;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: #2980b9;
    color: #fff;
    border-color: #2980b9;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .post-card {
    display: block;
    padding: 24px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .post-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    border-color: #d1d5db;
    transform: translateY(-1px);
  }

  .post-card h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 10px 0 8px;
    line-height: 1.3;
  }

  .post-card p {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #6b7280;
    margin: 0;
    line-height: 1.6;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Roboto Mono', monospace;
    font-size: 12px;
    color: #9ca3af;
  }

  .post-card-meta .category {
    background: linear-gradient(135deg, #2980b9, #3498db);
    color: #fff;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 11px;
    text-transform: lowercase;
    letter-spacing: 1px;
    font-weight: 500;
  }

  .post-tags {
    display: flex;
    gap: 6px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: 'Roboto Mono', monospace;
    font-size: 11px;
    color: #6b7280;
    padding: 3px 8px;
    border: 1px solid #e5e7eb;
    border-radius: 4px;
    background: #f9fafb;
  }

  .no-posts {
    font-family: 'Roboto Mono', monospace;
    font-size: 14px;
    color: #9ca3af;
    text-align: center;
    padding: 60px 0;
  }

  .search-box {
    margin-bottom: 20px;
  }

  #blog-search {
    width: 100%;
    padding: 10px 14px;
    font-family: 'Roboto Mono', monospace;
    font-size: 14px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: transparent;
    color: #1a1a1a;
    outline: none;
    transition: border-color 0.2s;
  }

  #blog-search::placeholder {
    color: #9ca3af;
  }

  #blog-search:focus {
    border-color: #2980b9;
  }

  @media (prefers-color-scheme: dark) {
    #blog-search { border-color: #334155; color: #f1f5f9; background: #1e293b; }
    #blog-search::placeholder { color: #64748b; }
    #blog-search:focus { border-color: #1a5276; }
    .blog-subtitle { color: #94a3b8; }
    .filter-btn { border-color: #334155; color: #94a3b8; }
    .filter-btn:hover, .filter-btn.active { background: #1a5276; border-color: #1a5276; color: #fff; }
    .post-card { background: #1e293b; border-color: #334155; }
    .post-card:hover { box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3); border-color: #475569; }
    .post-card h2 { color: #f1f5f9; }
    .post-card p { color: #94a3b8; }
    .post-card-meta { color: #64748b; }
    .post-card-meta .category { background: linear-gradient(135deg, #1a5276, #2471a3); }
    .tag { color: #94a3b8; border-color: #334155; background: #0f172a; }
    .no-posts { color: #64748b; }
  }
</style>

<script>
  // Category filter
  document.querySelectorAll('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });
  document.querySelector('.filter-btn')?.classList.add('active');

  // Search filter
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  searchInput?.addEventListener('input', () => applyFilters());

  function applyFilters() {
    const activeBtn = document.querySelector('.filter-btn.active') as HTMLElement;
    const cat = activeBtn?.getAttribute('data-category') || 'all';
    const query = searchInput?.value.toLowerCase().trim() || '';

    document.querySelectorAll('.post-card').forEach((card) => {
      const el = card as HTMLElement;
      const matchesCat = cat === 'all' || el.getAttribute('data-category') === cat;
      const text = el.textContent?.toLowerCase() || '';
      const matchesSearch = !query || text.includes(query);
      el.style.display = matchesCat && matchesSearch ? '' : 'none';
    });
  }
</script>
