  <!--========================================
    Latest Posts Section
  =========================================-->
  <section class="section" id="latest-posts">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Latest from the Blog</h2>
      </div>

      <div class="row">
        {posts.map((post) => (
          <div class="col-sm-6" data-aos="fade-up">
            <a href={`/blog/${post.id}/`} class="post-preview">
              <span class="post-preview-date">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' })}
                <span class="post-preview-sep">&middot;</span>
                {getReadTime(post.body)} min read
              </span>
              <h4>{post.data.title}</h4>
              <p>{post.data.excerpt}</p>
            </a>
          </div>
        ))}
      </div>

      <div class="text-center" data-aos="fade-up" style="margin-top: 24px;">
        <a href="/blog/" class="btn btn-custom">View All Posts</a>
      </div>

    </div>
  </section>

  <!--========================================
    Contact Section
  =========================================-->
  <section class="section contact-section" id="contact">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Contact Me</h2>
      </div>

      <form name="contact" method="POST" action="/thank-you/" data-netlify="true" netlify-honeypot="bot-field" class="contact-form" data-aos="fade-up">
        <p class="hidden" style="display:none">
          <label>Don't fill this out: <input name="bot-field"></label>
        </p>
        <div class="form-group">
          <div class="material-input">
            <input type="text" name="name" class="form-control" placeholder=" " required>
            <label>Name</label>
          </div>
        </div>
        <div class="form-group">
          <div class="material-input">
            <input type="email" name="email" class="form-control" placeholder=" " required>
            <label>Email</label>
          </div>
        </div>
        <div class="form-group">
          <div class="material-input">
            <textarea name="message" class="form-control" rows="3" placeholder=" " required></textarea>
            <label>Message</label>
          </div>
        </div>
        <button type="submit" class="btn btn-custom">Send Message</button>
      </form>
    </div>
  </section>
  </main>

  <!--========================================
    Footer
  =========================================-->
  <footer>
    <div class="container">
      <p class="copyright" data-aos="fade-up">
        Copyright &copy; LaPlante Web Development 2006-<span id="copyright-year"></span>.
      </p>
    </div>
  </footer>

  <!--========================================
    JavaScript Files
  =========================================-->
  <script is:inline defer src="/js/waves.min.js"></script>
  <script is:inline defer src="/js/script.js"></script>
</SiteLayout>

<style>
  .post-preview {
    display: block;
    padding: 20px 24px;
    margin-bottom: 20px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .post-preview:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    border-color: #d1d5db;
    transform: translateY(-2px);
  }
  .post-preview-date {
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    color: #9ca3af;
    font-weight: 400;
  }
  .post-preview-sep { color: #d1d5db; }
  .post-preview h4 {
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #111827;
    margin: 8px 0 6px;
    line-height: 1.35;
  }
  .post-preview p {
