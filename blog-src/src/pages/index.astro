---
import SiteLayout from '../layouts/SiteLayout.astro';
import Icon from '../components/Icon.astro';
import { getReadTime } from '../utils/readTime';
import { formatDateShort } from '../utils/format';
import { getSortedPosts } from '../utils/posts';
import { profile, summary, stats, skills, experience, certifications } from '../data/resume';
import { CAL_LINK } from '../config';

const posts = (await getSortedPosts()).slice(0, 4);
---

<SiteLayout title="Michael LaPlante - SVP of Information Security and Operations | Technology Leader | Security Executive | Software Engineer" description="Michael LaPlante - Technology executive with 15+ years of experience in information security, operations, and software engineering. SVP of Information Security and Operations.">
  <Fragment slot="head">
    <meta name="keywords" content="Michael LaPlante, Information Security, Technology Leader, Software Engineer, SVP, Chief Security Officer, Web Development">
    <meta name="author" content="Michael LaPlante">

    <!-- Structured Data - Person -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Michael LaPlante",
      "url": "https://michaellaplante.com",
      "image": "https://michaellaplante.com/images/mike-laplante-400.jpg",
      "jobTitle": "SVP of Information Security and Operations",
      "worksFor": {
        "@type": "Organization",
        "name": "Proforma"
      },
      "description": "Technology executive with 15+ years of experience in information security, operations, and software engineering.",
      "knowsAbout": ["Information Security", "Software Engineering", "Cloud Security", "AI Security", "Web Development", "TypeScript", "React", "Angular"],
      "sameAs": [
        "https://www.linkedin.com/in/mlaplante/",
        "https://twitter.com/laplantewebdev",
        "https://github.com/mlaplante",
        "https://www.facebook.com/Laplante.Michael"
      ]
    }
    </script>

    <!-- Structured Data - WebSite (enables sitelinks search in Google) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Michael LaPlante",
      "url": "https://michaellaplante.com",
      "description": "Technology executive with 15+ years of experience in information security, operations, and software engineering.",
      "author": {
        "@type": "Person",
        "name": "Michael LaPlante"
      }
    }
    </script>

    <!-- Preload critical resources for the portfolio page only -->
    <link rel="preload" href="/fonts/poppins/poppins-400.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/poppins/poppins-700.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/css/style.css" as="style">
    <link rel="preload" href="/images/mike-laplante-400.webp" as="image" type="image/webp" fetchpriority="high">

    <!-- CSS bundles for the portfolio page -->
    <link rel="stylesheet" type="text/css" href="/css/fonts.css">
    <link rel="stylesheet" href="/css/bootstrap-reboot.min.css">
    <link rel="stylesheet" href="/css/bootstrap-grid.min.css">
    <link rel="stylesheet" href="/css/bootstrap-utilities.min.css">
    <link rel="stylesheet" type="text/css" href="/css/style.css">
  </Fragment>

  <!-- Skip to Content Link for Accessibility -->
  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <!--========================================
    Menu
  =========================================-->
  <nav class="top-nav" aria-label="Main navigation">
    <div class="container">

      <button type="button" class="menu-btn white-btn" aria-label="Toggle menu" aria-expanded="false" aria-controls="site-menu">
        <span class="lines">
          <span class="l1"></span>
          <span class="l2"></span>
          <span class="l3"></span>
        </span>
      </button>

      <button class="dark-mode-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <span class="sun-icon">☀️</span>
        <span class="moon-icon">🌙</span>
      </button>

      <div class="menu" id="site-menu">
        <ul>
          <li>
            <a data-scroll href="#home">Home</a>
          </li>
          <li>
            <a data-scroll href="#about">About</a>
          </li>
          <li>
            <a href="/services/">Services</a>
          </li>
          <li>
            <a data-scroll href="#skills">Skills</a>
          </li>
          <li>
            <a data-scroll href="#experience">Experience</a>
          </li>
          <li>
            <a data-scroll href="#contact">Contact</a>
          </li>
          <li>
            <a href="/blog/">Blog</a>
          </li>
          <li>
            <a href="/uses/">Uses</a>
          </li>
          <li>
            <a href="/resume/">Resume</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!--========================================
    Main Section
  =========================================-->
  <main id="main-content">
  <section class="main-section" id="home" aria-label="Introduction">
    <div class="container">

      <p class="briefing-label" data-aos="fade-up">SVP of Information Security and Operations</p>

      <!-- Your Name -->
      <h1 class="intro-name" data-aos="fade-up">I am <strong>Michael <br>La Plante</strong></h1>

      <!-- Person Image -->
      <div class="person-img" data-aos="zoom-out-up">
        <picture>
          <source srcset="/images/mike-laplante-400.webp" type="image/webp">
          <img src="/images/mike-laplante-400.jpg" alt="Michael LaPlante" width="400" height="400" loading="eager" fetchpriority="high">
        </picture>
      </div>

      <!-- CTA -->
      <div class="intro-actions" data-aos="fade-up">
        <a href="#contact" data-scroll class="btn btn-custom">Schedule a Consultation</a>
        <a href="/resume/" class="btn btn-custom btn-ghost">View Résumé</a>
      </div>

    </div>

    <div class="stat-readout" aria-label="Career impact by the numbers">
      <div class="container">
        <div class="stat-readout-grid">
          {stats.map((stat) => (
            <div class="stat-readout-item">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section about-section" id="about">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>About Me</h2>
      </div>

      <!-- about text -->
      <div class="about-text">

        {summary.map((para, i) => (
          <p class={i === 0 ? 'large' : undefined} data-aos="fade-up" data-aos-offset={i === 0 ? '0' : undefined}>
            {para}
          </p>
        ))}

      </div>

      <!-- social links -->
      <ul class="social-links" data-aos="fade-up">
        {profile.links.map((link) => (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
          </li>
        ))}
      </ul>

    </div>
  </section>

  <!--========================================
    Services Section
  =========================================-->
  <section class="section services-section" id="services">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Consulting Services</h2>
      </div>

      <div class="row">
        <div class="col-sm-6">
          <div class="service" data-aos="fade-up">
            <Icon name="shield" />
            <h3>Security Architecture Reviews</h3>
            <p>Assess your infrastructure, identify gaps, and design defense-in-depth strategies tailored to your risk profile and compliance requirements.</p>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="service" data-aos="fade-up">
            <Icon name="cloud" />
            <h3>Cloud Security Strategy</h3>
            <p>Build secure multi-cloud architectures across AWS, Azure, and GCP with zero-trust principles, least-privilege access, and continuous monitoring.</p>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-sm-6">
          <div class="service" data-aos="fade-up">
            <Icon name="lock" />
            <h3>Compliance &amp; Risk Assessment</h3>
            <p>Navigate SOC 2, ISO 27001, HIPAA, and PCI-DSS with practical frameworks that satisfy auditors without slowing your teams down.</p>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="service" data-aos="fade-up">
            <Icon name="lightbulb" />
            <h3>Engineering Leadership Advisory</h3>
            <p>Scale engineering organizations, establish DevSecOps practices, and build the security culture that keeps your company out of the headlines.</p>
          </div>
        </div>
      </div>

      <div class="text-center intro-actions" data-aos="fade-up" style="margin-top: 24px;">
        <a href="#contact" data-scroll class="btn btn-custom">Discuss Your Needs</a>
        <a href="/services/" class="btn btn-custom btn-ghost">See Full Services &rarr;</a>
      </div>
    </div>
  </section>

  <!--========================================
    Expertise Section
  =========================================-->
  <section class="section skills-section" id="skills">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Areas of Expertise</h2>
      </div>

      <div class="row">
        {skills.map((skill) => (
          <div class="col-sm-6 col-md-4" data-aos="fade-up">
            <div class="service">
              <h3>{skill.name}</h3>
              <p>{skill.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!--========================================
    Certifications Section
  =========================================-->
  {certifications.length > 0 && (
  <section class="section skills-section" id="certifications">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Certifications</h2>
      </div>

      <div class="row">
        {certifications.map((cert) => (
          <div class="col-sm-6 col-md-4" data-aos="fade-up">
            <div class="service">
              <h3>
                {cert.url ? (
                  <a href={cert.url} target="_blank" rel="noopener noreferrer">{cert.name}</a>
                ) : (
                  cert.name
                )}
              </h3>
              <p>{cert.issuer}{cert.year ? ` · ${cert.year}` : ''}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
  )}

  <!--========================================
    Experience Section
  =========================================-->
  <section class="section experience-section" id="experience">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>My Experience</h2>
      </div>

      <ul class="timeline">

        {experience.map((job) => (
          <li class={job.current ? 'current' : undefined} data-aos="fade-up">
            <div class="date">{job.date}</div>
            <div class="content">
              <h3>{job.company}</h3>
              <span>{job.role}</span>
              <p>{job.description}</p>
            </div>
          </li>
        ))}

      </ul>
    </div>
  </section>

  <!--========================================
    Latest Posts Section
  =========================================-->
  <section class="section" id="latest-posts">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Latest from the Blog</h2>
      </div>

      <div class="row">
        {posts.map((post) => (
          <div class="col-sm-6" data-aos="fade-up">
            <a href={`/blog/${post.id}/`} class="post-preview">
              <span class="post-preview-date">
                {formatDateShort(post.data.date)}
                <span class="post-preview-sep">&middot;</span>
                {getReadTime(post.body)} min read
              </span>
              <h3>{post.data.title}</h3>
              <p>{post.data.excerpt}</p>
            </a>
          </div>
        ))}
      </div>

      <div class="text-center" data-aos="fade-up" style="margin-top: 24px;">
        <a href="/blog/" class="btn btn-custom">View All Posts</a>
      </div>

    </div>
  </section>

  <!--========================================
    Contact Section
  =========================================-->
  <section class="section contact-section" id="contact">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Contact Me</h2>
      </div>

      {CAL_LINK && (
        <p class="contact-booking-note" data-aos="fade-up">
          Want to skip the back-and-forth? <a href="/services/#book">Book a call directly</a>.
        </p>
      )}

      <form name="contact" method="POST" action="/api/contact" class="contact-form" data-aos="fade-up">
        <p class="hidden" style="display:none" aria-hidden="true">
          <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off"></label>
        </p>
        <div class="form-group">
          <div class="material-input">
            <input type="text" id="contact-name" name="name" class="form-control" placeholder=" " required>
            <label for="contact-name">Name</label>
          </div>
        </div>
        <div class="form-group">
          <div class="material-input">
            <input type="email" id="contact-email" name="email" class="form-control" placeholder=" " required>
            <label for="contact-email">Email</label>
          </div>
        </div>
        <div class="form-group">
          <div class="material-input">
            <textarea id="contact-message" name="message" class="form-control" rows="3" placeholder=" " required></textarea>
            <label for="contact-message">Message</label>
          </div>
        </div>
        <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>
        <button type="submit" class="btn btn-custom">Send Message</button>
      </form>
      <script is:inline defer src="/js/turnstile.js"></script>
    </div>
  </section>
  </main>

  <!--========================================
    Footer
  =========================================-->
  <footer>
    <div class="container">
      <p class="copyright" data-aos="fade-up">
        Copyright &copy; LaPlante Web Development 2006-<span id="copyright-year"></span>.
        <a href="/privacy/">Privacy</a>
      </p>
    </div>
  </footer>

  <!--========================================
    JavaScript Files
  =========================================-->
  <script is:inline defer src="/js/script.js"></script>
</SiteLayout>

<style>
  /* .post-preview card styles live in public/css/style.css with the rest of
     the portfolio card language — /css/* has a fingerprint fallback in the
     Worker, so those styles stay correct even when stale HTML is served. */

  .contact-booking-note {
    margin: -10px 0 24px;
    font-size: 15px;
  }
  .contact-booking-note a {
    color: #2980b9;
    font-weight: 600;
    text-decoration: none;
  }
  .contact-booking-note a:hover { opacity: 0.7; }
  :global([data-theme='dark']) .contact-booking-note a { color: #60a5fa; }
</style>
