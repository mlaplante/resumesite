---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Michael LaPlante - Uses | Tools, Hardware &amp; Software" description="The tools, hardware, and software Michael LaPlante uses daily for security leadership, engineering, and development.">
  <Fragment slot="head">
    <!-- SEO Meta Tags -->
    <meta name="keywords" content="Michael LaPlante, Uses, Tools, Hardware, Software, Development Setup, Workspace">
    <meta name="author" content="Michael LaPlante">

    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content="Michael LaPlante - Uses | Tools, Hardware &amp; Software">
    <meta property="og:description" content="The tools, hardware, and software Michael LaPlante uses daily for security leadership, engineering, and development.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://michaellaplante.com/uses/">
    <meta property="og:image" content="https://michaellaplante.com/images/mike-laplante-400.jpg">

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@laplantewebdev">
    <meta name="twitter:title" content="Michael LaPlante - Uses | Tools, Hardware &amp; Software">
    <meta name="twitter:description" content="The tools, hardware, and software Michael LaPlante uses daily for security leadership, engineering, and development.">
    <meta name="twitter:image" content="https://michaellaplante.com/images/mike-laplante-400.jpg">

    <!-- Canonical URL -->
    <link rel="canonical" href="https://michaellaplante.com/uses/">

    <!-- CSS Stylesheets -->
    <link rel="stylesheet" type="text/css" href="/css/fonts.css">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="/css/linea.css">
    <link rel="stylesheet" type="text/css" href="/css/style.css">
  </Fragment>

  <!-- Skip to Content Link for Accessibility -->
  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <!--========================================
    Menu
  =========================================-->
  <nav class="top-nav" aria-label="Main navigation">
    <div class="container">

      <a href="#" class="menu-btn" aria-label="Toggle menu" aria-expanded="false">
        <span class="lines">
          <span class="l1"></span>
          <span class="l2"></span>
          <span class="l3"></span>
        </span>
      </a>

      <button class="dark-mode-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <span class="sun-icon">☀️</span>
        <span class="moon-icon">🌙</span>
      </button>

      <div class="menu" role="menu">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/uses/">Uses</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!--========================================
    Main Content
  =========================================-->
  <main id="main-content">

  <!-- Page Header -->
  <section class="section" id="uses-header" style="padding-top: 120px;">
    <div class="container">
      <div class="section-header" data-aos="fade-up">
        <h1 style='font-size: 18px; font-weight: 700; font-family: "Roboto Mono", monospace; text-transform: lowercase; letter-spacing: 2px; position: relative; display: inline-block;'>uses</h1>
      </div>
      <p data-aos="fade-up">The tools, hardware, and software I use daily for security leadership, engineering, and creative work.</p>
    </div>
  </section>

  <!--========================================
    Hardware Section
  =========================================-->
  <section class="section" id="hardware">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Hardware</h2>
      </div>

      <div class="row">
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.apple.com/macbook-air/" target="_blank" rel="noopener">13" MacBook Air M4</a></h4>
            <p>My daily driver for everything from code to presentations.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.samsung.com/us/monitors/gaming/49-odyssey-g9-dqhd-240hz-1ms-gtg-displayhdr-1000-gaming-monitor-sku-ls49cg954enxza/" target="_blank" rel="noopener">49" Samsung Odyssey G9</a></h4>
            <p>Ultrawide curved monitor for multi-window workflows.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.apple.com/iphone-17-pro/" target="_blank" rel="noopener">iPhone 17 Pro Max</a></h4>
            <p>Always on, always connected.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.sonos.com/en-us/shop/five" target="_blank" rel="noopener">Sonos Five</a> + <a href="https://www.sonos.com/en-us/shop/play1.html" target="_blank" rel="noopener">Play:1</a> Surround</h4>
            <p>Background music and podcast listening while working.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.shure.com/en-US/products/microphones/sm7b" target="_blank" rel="noopener">Shure SM7B Microphone</a></h4>
            <p>For meetings, recordings, and speaking sessions.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.elgato.com/us/en/p/wave-mic-arm-lp" target="_blank" rel="noopener">Elgato Wave Mic Arm LP</a></h4>
            <p>Low-profile boom arm to keep the desk clean.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.bhphotovideo.com/c/product/1667800-REG/sony_ilce_7m4_b_alpha_a7_iv_mirrorless.html" target="_blank" rel="noopener">Sony A7 IV</a> + <a href="https://www.sigma-global.com/en/lenses/a019_24_70_28/" target="_blank" rel="noopener">Sigma 24-70mm f/2.8</a></h4>
            <p>Photography and video content creation.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.apple.com/airpods-pro/" target="_blank" rel="noopener">AirPods Pro 3 (USB-C)</a></h4>
            <p>Noise cancellation for focus and calls.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.apple.com/apple-watch-ultra-3/" target="_blank" rel="noopener">Apple Watch Ultra 3</a></h4>
            <p>Notifications, fitness tracking, and quick glances.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.keychron.com/products/keychron-k2-he-wireless-magnetic-switch-custom-keyboard-resin-edition" target="_blank" rel="noopener">Keychron K2 Resin Edition (Magnetic Switches)</a></h4>
            <p>Mechanical keyboard for a satisfying typing experience.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.logitech.com/en-us/shop/p/mx-master-3s" target="_blank" rel="noopener">Logitech MX Master 3S</a></h4>
            <p>Ergonomic mouse with smooth scrolling.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.nomatic.com/products/the-nomatic-backpack" target="_blank" rel="noopener">Nomatic Backpack</a></h4>
            <p>Carries everything for work and travel.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.hermanmiller.com/products/seating/office-chairs/aeron-chair/" target="_blank" rel="noopener">Herman Miller Aeron Chair</a></h4>
            <p>Ergonomic seating for long work sessions.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!--========================================
    Software Section
  =========================================-->
  <section class="section" id="software">
    <div class="container">

      <div class="section-header" data-aos="fade-up">
        <h2>Software</h2>
      </div>

      <div class="row">
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.warp.dev/" target="_blank" rel="noopener">Warp Terminal</a></h4>
            <p>Modern terminal with AI-powered command suggestions.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://code.visualstudio.com/" target="_blank" rel="noopener">VS Code</a> + <a href="https://github.com/features/copilot" target="_blank" rel="noopener">GitHub Copilot</a> / <a href="https://claude.ai/code" target="_blank" rel="noopener">Claude Code</a></h4>
            <p>Primary editor with AI-assisted development.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://git-scm.com/" target="_blank" rel="noopener">Git</a> &amp; <a href="https://cli.github.com/" target="_blank" rel="noopener">GitHub CLI</a></h4>
            <p>Version control and repository management from the terminal.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.google.com/chrome/" target="_blank" rel="noopener">Chrome Browser</a></h4>
            <p>Primary browser with DevTools for development and debugging.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.alfredapp.com/" target="_blank" rel="noopener">AlfredApp</a></h4>
            <p>Spotlight replacement with custom workflows and snippets.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://slack.com/" target="_blank" rel="noopener">Slack</a>, <a href="https://discord.com/" target="_blank" rel="noopener">Discord</a> &amp; <a href="https://zoom.us/" target="_blank" rel="noopener">Zoom</a></h4>
            <p>Team communication and video conferencing.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://1password.com/" target="_blank" rel="noopener">1Password</a></h4>
            <p>Password management for personal and team credentials.</p>
          </div>
        </div>
        <div class="col-md-6" data-aos="fade-up">
          <div class="service">
            <h4><a href="https://www.apple.com/icloud/" target="_blank" rel="noopener">iCloud+ with Advanced Data Protection</a></h4>
            <p>End-to-end encrypted cloud storage and sync.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  </main>

  <!--========================================
    Footer
  =========================================-->
  <footer>
    <div class="container">
      <p class="copyright" data-aos="fade-up">
        Copyright &copy; LaPlante Web Development 2006-<span id="copyright-year"></span>.
      </p>
    </div>
  </footer>

  <!--========================================
    JavaScript Files
  =========================================-->
  <script is:inline src="/js/script.js"></script>
</SiteLayout>
