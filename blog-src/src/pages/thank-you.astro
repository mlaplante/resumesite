---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Thank You - Michael LaPlante">
  <Fragment slot="head">
    <meta name="robots" content="noindex">
    <link rel="stylesheet" type="text/css" href="/css/fonts.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap-reboot.min.css" rel="stylesheet" integrity="sha384-DMXPlKUqiacJPvmloxO8WEKmweTP1X7QWc/yGAFhycsyFqem+stvdOQ4mrtuETGJ" crossorigin="anonymous">
    <link rel="stylesheet" type="text/css" href="/css/style.css">
  </Fragment>
  <div class="thank-you">
    <div>
      <!-- Animated robot SVG -->
      <svg class="robot" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 140" fill="none">
        <!-- Antenna -->
        <line class="robot-draw" x1="60" y1="8" x2="60" y2="28" stroke-width="3" stroke-linecap="round"/>
        <circle class="robot-antenna-dot" cx="60" cy="6" r="4"/>
        <!-- Head -->
        <rect class="robot-draw robot-head" x="30" y="28" width="60" height="44" rx="10" stroke-width="3"/>
        <!-- Eyes -->
        <circle class="robot-eye robot-eye-left" cx="45" cy="50" r="6"/>
        <circle class="robot-eye robot-eye-right" cx="75" cy="50" r="6"/>
        <!-- Mouth -->
        <rect class="robot-draw" x="44" y="60" width="32" height="4" rx="2" stroke-width="2"/>
        <!-- Body -->
        <rect class="robot-draw" x="34" y="76" width="52" height="36" rx="6" stroke-width="3"/>
        <!-- Arms -->
        <line class="robot-draw robot-arm-left" x1="34" y1="86" x2="14" y2="96" stroke-width="3" stroke-linecap="round"/>
        <line class="robot-draw robot-arm-right" x1="86" y1="86" x2="106" y2="96" stroke-width="3" stroke-linecap="round"/>
        <!-- Arm hands (circles) -->
        <circle class="robot-hand" cx="12" cy="98" r="4"/>
        <circle class="robot-hand" cx="108" cy="98" r="4"/>
        <!-- Chest detail -->
        <rect class="robot-draw" x="50" y="84" width="20" height="12" rx="3" stroke-width="2"/>
        <!-- Chest light -->
        <circle class="robot-chest-light" cx="60" cy="90" r="3"/>
        <!-- Legs -->
        <line class="robot-draw" x1="48" y1="112" x2="48" y2="130" stroke-width="3" stroke-linecap="round"/>
        <line class="robot-draw" x1="72" y1="112" x2="72" y2="130" stroke-width="3" stroke-linecap="round"/>
        <!-- Feet -->
        <rect class="robot-draw" x="38" y="128" width="20" height="6" rx="3" stroke-width="2"/>
        <rect class="robot-draw" x="62" y="128" width="20" height="6" rx="3" stroke-width="2"/>
      </svg>
      <h1>Thank you!</h1>
      <p>Your message has been sent. I'll get back to you soon.</p>
      <a href="/" class="btn btn-custom">Back to Home</a>
    </div>
  </div>
  <script is:inline defer src="/js/script.js"></script>
</SiteLayout>

<style>
  .thank-you {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding: 40px 20px;
  }
  .thank-you h1 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    animation: fadeSlideUp 0.6s ease 1.2s both;
  }
  .thank-you p {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 30px;
    animation: fadeSlideUp 0.6s ease 1.5s both;
  }
  .thank-you .btn {
    animation: fadeSlideUp 0.6s ease 1.8s both;
  }
  :global(body.dark-mode) .thank-you p {
    color: #b0b0b0;
  }

  /* Animated robot */
  .robot {
    width: 120px;
    height: 140px;
    margin: 0 auto 28px;
    display: block;
  }

  /* Draw-on effect for all stroked elements */
  .robot-draw {
    stroke: #2980b9;
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    animation: robotDraw 1.2s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }

  /* Antenna tip blinks */
  .robot-antenna-dot {
    fill: #2980b9;
    opacity: 0;
    animation: fadeIn 0.3s ease 0.8s forwards, blink 1.5s ease-in-out 2s infinite;
  }

  /* Eyes pop in and look around */
  .robot-eye {
    fill: #2980b9;
    opacity: 0;
    animation: eyePopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.9s forwards;
  }
  .robot-eye-left {
    transform-origin: 45px 50px;
    animation: eyePopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.9s forwards,
               eyeLookAround 3s ease-in-out 2.5s infinite;
  }
  .robot-eye-right {
    transform-origin: 75px 50px;
    animation: eyePopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 1s forwards,
               eyeLookAround 3s ease-in-out 2.5s infinite;
  }

  /* Hands pop in */
  .robot-hand {
    fill: #2980b9;
    opacity: 0;
    animation: fadeIn 0.3s ease 1s forwards;
  }

  /* Chest light pulses */
  .robot-chest-light {
    fill: #27ae60;
    opacity: 0;
    animation: fadeIn 0.3s ease 1.1s forwards, pulse 2s ease-in-out 1.5s infinite;
  }

  /* Arms wave after drawing */
  .robot-arm-left {
    transform-origin: 34px 86px;
    animation: robotDraw 1.2s cubic-bezier(0.65, 0, 0.45, 1) forwards,
               waveLeft 1.5s ease-in-out 2s infinite;
  }
  .robot-arm-right {
    transform-origin: 86px 86px;
    animation: robotDraw 1.2s cubic-bezier(0.65, 0, 0.45, 1) forwards,
               waveRight 1.5s ease-in-out 2.2s infinite;
  }

  /* Gentle float for entire robot */
  .robot {
    animation: robotFloat 3s ease-in-out 1.5s infinite;
  }

  @keyframes robotDraw {
    100% { stroke-dashoffset: 0; }
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @keyframes eyePopIn {
    from { opacity: 0; transform: scale(0); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes eyeLookAround {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(2px); }
    75% { transform: translateX(-2px); }
  }

  @keyframes blink {
    0%, 90%, 100% { opacity: 1; }
    95% { opacity: 0.2; }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  @keyframes waveLeft {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-12deg); }
  }

  @keyframes waveRight {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(12deg); }
  }

  @keyframes robotFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    .robot-draw { stroke: #60a5fa; }
    .robot-antenna-dot { fill: #60a5fa; }
    .robot-eye { fill: #60a5fa; }
    .robot-hand { fill: #60a5fa; }
    .robot-chest-light { fill: #4ade80; }
  }
</style>
