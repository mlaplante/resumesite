---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout title="Thank You - Michael LaPlante">
  <Fragment slot="head">
    <meta name="robots" content="noindex">
    <link rel="stylesheet" type="text/css" href="/css/fonts.css">
    <link rel="stylesheet" href="/css/bootstrap-reboot.min.css">
    <link rel="stylesheet" type="text/css" href="/css/style.css">
  </Fragment>
  <div class="thank-you">
    <div>
      <!-- Animated Anima Bot SVG -->
      <svg class="robot" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 220" fill="none">
        <defs>
          <linearGradient id="bodyGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#ebf4fc"/>
            <stop offset="100%" stop-color="#dde1e7"/>
          </linearGradient>
        </defs>
        <!-- Shadow -->
        <ellipse class="robot-shadow" cx="100" cy="200" rx="50" ry="10" fill="#c3c3c3" opacity="0.4"/>
        <!-- Body -->
        <g class="robot-body">
          <!-- Neck / connector -->
          <ellipse cx="100" cy="155" rx="40" ry="12" fill="#d0d0d0"/>
          <!-- Body shape -->
          <path d="M60,110 Q60,155 100,158 Q140,155 140,110 Q140,90 100,88 Q60,90 60,110Z" fill="url(#bodyGrad)" stroke="#ccd0d5" stroke-width="1.5"/>
          <!-- Ears -->
          <ellipse class="robot-ear-left" cx="52" cy="60" rx="14" ry="22" fill="#e1e1e1" stroke="#ccc" stroke-width="1"/>
          <ellipse class="robot-ear-right" cx="148" cy="60" rx="14" ry="22" fill="#e1e1e1" stroke="#ccc" stroke-width="1"/>
          <!-- Head -->
          <path d="M58,30 Q58,10 100,8 Q142,10 142,30 L142,85 Q142,95 100,97 Q58,95 58,85Z" fill="url(#bodyGrad)" stroke="#ccd0d5" stroke-width="1.5"/>
          <!-- Face screen -->
          <rect x="68" y="35" width="64" height="48" rx="16" fill="#212121"/>
          <!-- Eyes -->
          <rect class="robot-eye-left" x="78" y="42" width="10" height="28" rx="5" fill="#7d8aff"/>
          <rect class="robot-eye-right" x="112" y="42" width="10" height="28" rx="5" fill="#7d8aff"/>
          <!-- Mouth - subtle smile -->
          <path d="M88,73 Q100,79 112,73" stroke="#3a3a3a" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        </g>
        <!-- Arms -->
        <g class="robot-arm-left">
          <path d="M58,105 Q38,110 30,130 Q26,140 32,145 Q40,148 44,138 L55,115" fill="url(#bodyGrad)" stroke="#ccd0d5" stroke-width="1.5"/>
          <circle cx="32" cy="145" r="8" fill="url(#bodyGrad)" stroke="#ccd0d5" stroke-width="1"/>
        </g>
        <g class="robot-arm-right">
          <path d="M142,105 Q162,110 170,130 Q174,140 168,145 Q160,148 156,138 L145,115" fill="url(#bodyGrad)" stroke="#ccd0d5" stroke-width="1.5"/>
          <circle cx="168" cy="145" r="8" fill="url(#bodyGrad)" stroke="#ccd0d5" stroke-width="1"/>
        </g>
      </svg>
      <h1>Thank you!</h1>
      <p>Your message has been sent. I'll get back to you soon.</p>
      <a href="/" class="btn btn-custom">Back to Home</a>
    </div>
  </div>
  <script is:inline defer src="/js/script.js"></script>
</SiteLayout>

<style>
  .thank-you {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding: 40px 20px;
  }
  .thank-you h1 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    animation: fadeSlideUp 0.6s ease 1.2s both;
  }
  .thank-you p {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 30px;
    animation: fadeSlideUp 0.6s ease 1.5s both;
  }
  .thank-you .btn {
    animation: fadeSlideUp 0.6s ease 1.8s both;
  }
  :global(body.dark-mode) .thank-you p {
    color: #b0b0b0;
  }

  /* Robot container */
  .robot {
    width: 160px;
    height: 180px;
    margin: 0 auto 28px;
    display: block;
    opacity: 0;
    animation: fadeIn 0.6s ease 0.2s forwards;
  }

  /* Gentle bob for the whole body group */
  .robot-body {
    animation: bodyBob 2.5s ease-in-out infinite;
  }

  /* Shadow scales with bob */
  .robot-shadow {
    animation: shadowPulse 2.5s ease-in-out infinite;
  }

  /* Eye blink */
  .robot-eye-left, .robot-eye-right {
    animation: eyeBlink 4s ease-in-out 1s infinite;
  }

  /* Arm wave - left arm subtle idle sway */
  .robot-arm-left {
    transform-origin: 58px 105px;
    animation: armSwayLeft 3s ease-in-out infinite;
  }

  /* Right arm waves hello */
  .robot-arm-right {
    transform-origin: 142px 105px;
    animation: armWaveRight 1.8s ease-in-out 0.5s infinite;
  }

  /* Ear wiggle */
  .robot-ear-left {
    transform-origin: 52px 60px;
    animation: earWiggle 3s ease-in-out 0.3s infinite;
  }
  .robot-ear-right {
    transform-origin: 148px 60px;
    animation: earWiggle 3s ease-in-out 0.6s infinite;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @keyframes bodyBob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes shadowPulse {
    0%, 100% { transform: scaleX(1); opacity: 0.4; }
    50% { transform: scaleX(0.85); opacity: 0.25; }
  }

  @keyframes eyeBlink {
    0%, 42%, 48%, 100% { transform: scaleY(1); }
    45% { transform: scaleY(0.1); }
  }

  @keyframes armSwayLeft {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-5deg); }
  }

  @keyframes armWaveRight {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-20deg); }
    50% { transform: rotate(5deg); }
    75% { transform: rotate(-15deg); }
  }

  @keyframes earWiggle {
    0%, 100% { transform: scaleX(1); }
    50% { transform: scaleX(1.08); }
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Dark mode - slightly brighter robot */
  @media (prefers-color-scheme: dark) {
    .robot-eye-left, .robot-eye-right { fill: #93a0ff; }
  }
</style>
