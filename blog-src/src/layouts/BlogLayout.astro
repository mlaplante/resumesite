---
import BaseHead from '../components/BaseHead.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  showProgressBar?: boolean;
}

const {
  title,
  description,
  image,
  ogType = 'website',
  noindex = false,
  showProgressBar = false,
} = Astro.props;
const baseUrl = '/blog';
const fullTitle = `${title} | Michael LaPlante`;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title={fullTitle}
      description={description}
      image={image}
      ogType={ogType}
      noindex={noindex}
    />
    <link rel="preload" href="/fonts/poppins/poppins-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins/poppins-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" type="text/css" href="/css/fonts.css" />
    <link rel="stylesheet" href="/css/bootstrap-reboot.min.css" />
    <link rel="stylesheet" href="/css/bootstrap-grid.min.css" />
    <slot name="head" />
  </head>
  <body>
    <a href="#blog-main-content" class="skip-to-content">Skip to main content</a>
    {showProgressBar && (
      <div class="reading-progress-container" aria-hidden="true">
        <div class="reading-progress-bar"></div>
      </div>
    )}
    <nav class="blog-nav" aria-label="Blog navigation">
      <div class="container">
        <a href="/" class="nav-brand" aria-label="Michael LaPlante home">Michael LaPlante</a>
        <button
          class="nav-toggle"
          type="button"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="blog-nav-links"
        >
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>
        <div class="nav-links" id="blog-nav-links">
          <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Home</a>
          <a href="/services/" aria-current={currentPath === '/services/' ? 'page' : undefined}>Services</a>
          <a href={baseUrl} aria-current={currentPath.startsWith('/blog/') && !currentPath.includes('/about/') ? 'page' : undefined}>Blog</a>
          <a href={`${baseUrl}/about/`} aria-current={currentPath === '/blog/about/' ? 'page' : undefined}>About</a>
          <a href="/uses/" aria-current={currentPath === '/uses/' ? 'page' : undefined}>Uses</a>
          <a href="/resume/" aria-current={currentPath === '/resume/' ? 'page' : undefined}>Résumé</a>
          <a href={`${baseUrl}/rss.xml`} title="RSS Feed">RSS</a>
        </div>
        <button class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
          <span class="sun-icon" aria-hidden="true">☀️</span>
          <span class="moon-icon" aria-hidden="true">🌙</span>
        </button>
      </div>
    </nav>
    <!-- External so the CSP can serve script-src without 'unsafe-inline'. -->
    <script is:inline defer src="/js/blog-nav.js"></script>
    <main id="blog-main-content" class="blog-content">
      <slot />
    </main>
    <footer class="blog-site-footer">
      <div class="container">
        <p>© Michael LaPlante <span aria-hidden="true">·</span> <a href="/privacy/">Privacy</a> <span aria-hidden="true">·</span> <a href="/blog/rss.xml">RSS</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/blog.css';

  /* Skip link — hidden until focused, then anchored top-left. */
  .skip-to-content {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 200;
    background: #1a5276;
    color: #fff;
    padding: 8px 16px;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    border-radius: 0 0 6px 0;
  }
  .skip-to-content:focus {
    left: 0;
  }
</style>
