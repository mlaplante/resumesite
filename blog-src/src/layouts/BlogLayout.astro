---
import BaseHead from '../components/BaseHead.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  showProgressBar?: boolean;
}

const {
  title,
  description,
  image,
  ogType = 'website',
  noindex = false,
  showProgressBar = false,
} = Astro.props;
const baseUrl = '/blog';
const fullTitle = `${title} | Michael LaPlante`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title={fullTitle}
      description={description}
      image={image}
      ogType={ogType}
      noindex={noindex}
    />
    <link rel="preload" href="/fonts/poppins/poppins-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins/poppins-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" type="text/css" href="/css/fonts.css" />
    <link rel="stylesheet" href="/css/bootstrap-reboot.min.css" />
    <link rel="stylesheet" href="/css/bootstrap-grid.min.css" />
    <slot name="head" />
  </head>
  <body>
    <a href="#blog-main-content" class="skip-to-content">Skip to main content</a>
    {showProgressBar && (
      <div class="reading-progress-container" aria-hidden="true">
        <div class="reading-progress-bar"></div>
      </div>
    )}
    <nav class="blog-nav" aria-label="Blog navigation">
      <div class="container">
        <a href="/">Michael LaPlante</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/services/">Services</a>
          <a href={baseUrl}>Blog</a>
          <a href={`${baseUrl}/about/`}>About</a>
          <a href="/uses/">Uses</a>
          <a href="/resume/">Résumé</a>
          <a href={`${baseUrl}/rss.xml`} title="RSS Feed">RSS</a>
        </div>
      </div>
    </nav>
    <main id="blog-main-content" class="blog-content">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/blog.css';

  /* Skip link — hidden until focused, then anchored top-left. */
  .skip-to-content {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 200;
    background: #1a5276;
    color: #fff;
    padding: 8px 16px;
    text-decoration: none;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    border-radius: 0 0 6px 0;
  }
  .skip-to-content:focus {
    left: 0;
  }
</style>
