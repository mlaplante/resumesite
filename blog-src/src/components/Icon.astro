---
// Inline SVG icons. The three glyph paths (cloud, lightbulb, lock) were
// extracted 1:1 from the retired linea icon font; shield is hand-drawn in the
// same thin-outline style (the font never had one). viewBox matches the
// font's em box so the icons render at the exact size/position the font did.
interface Props {
  name: 'shield' | 'cloud' | 'lock' | 'lightbulb';
}

const { name } = Astro.props;

const paths: Record<Props['name'], string> = {
