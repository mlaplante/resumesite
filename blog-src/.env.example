# Public site environment variables (exposed to client)
PUBLIC_TURNSTILE_SITE_KEY=0x000000000000000000000000

# Worker secrets (set via `wrangler secret put <NAME>` in production;
# put values in .dev.vars for local `wrangler dev`)
TURNSTILE_SECRET=
FE_API_KEY=
CONTACT_FROM=contact@example.com
CONTACT_TO=you@example.com
